# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (Prisma)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Auth
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI
ANTHROPIC_API_KEY=your_claude_api_key

# Enrichment APIs (optional, users can BYO)
APOLLO_API_KEY=your_apollo_key
HUNTER_API_KEY=your_hunter_key

# Queue (Railway)
REDIS_URL=redis://default:password@your-railway-redis:6379

# Redis connection (local Docker: localhost:6379, Railway: use private URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_FAMILY=4

# Payments
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable

# Email
RESEND_API_KEY=your_resend_key

# Cron Security
CRON_SECRET=your_cron_secret

# Backward-compat aliases currently used in repo
DIRECT_DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Gmail API (Phase 5 — Pro tier send)
# Google OAuth credentials for gmail.send scope (separate from Supabase login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# 64 hex chars — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GMAIL_TOKEN_ENCRYPTION_KEY=

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Error Tracking (Sentry)
SENTRY_DSN=https://xxxxx@oyyy.ingest.sentry.io/zzzzz
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=korvo
SENTRY_AUTH_TOKEN=sntrys_xxxxx
