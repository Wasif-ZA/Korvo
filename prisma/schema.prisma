// Prisma schema for Korvo
// Dual-connection pattern: pooler (port 6543) for runtime, direct (port 5432) for migrations
// See: .planning/phases/01-foundation/01-RESEARCH.md Pattern 1

datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// ============================================
// PROFILE
// 1:1 with Supabase auth.users
// Auto-created via trigger on auth.users INSERT
// ============================================
model Profile {
  id                    String    @id @default(uuid())
  userId                String    @unique @map("user_id") // maps to auth.users.id
  email                 String
  fullName              String?   @map("full_name")
  avatarUrl             String?   @map("avatar_url")
  plan                  String    @default("free")                   // "free" | "pro" — ONLY updated by webhook handler
  stripeCustomerId      String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?   @unique @map("stripe_subscription_id")
  searchesUsedThisMonth Int       @default(0) @map("searches_used_this_month")
  draftsUsedThisMonth   Int       @default(0) @map("drafts_used_this_month")
  searchesResetAt       DateTime  @default(now()) @map("searches_reset_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  searches Search[]

  @@map("profiles")
}

// ============================================
// SEARCH
// Nullable userId supports guest searches (D-15)
// sessionId tracks anonymous guest sessions for later adoption
// Soft delete via deletedAt (D-16)
// ============================================
model Search {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")    // nullable for guest searches
  sessionId String?   @map("session_id") // guest session UUID; null for authenticated searches
  company   String
  role      String
  location  String?
  status    String    @default("pending") // pending | processing | completed | failed
  deletedAt DateTime? @map("deleted_at")  // soft delete (D-16)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  profile  Profile? @relation(fields: [userId], references: [userId])
  contacts Contact[]

  @@map("searches")
}

// ============================================
// CONTACT
// Linked to a search; holds all enriched contact data
// pipelineStage tracks outreach pipeline progress
// Soft delete via deletedAt (D-16)
// ============================================
model Contact {
  id                    String    @id @default(uuid())
  searchId              String    @map("search_id")
  name                  String
  title                 String
  email                 String?
  emailConfidence       String?   @map("email_confidence") // "high" | "medium" | "low"
  score                 Int?                               // 0-100 response probability
  scoreBreakdown        Json?     @map("score_breakdown")
  researchBackground    String?   @map("research_background")
  researchAskThis       String?   @map("research_ask_this")
  researchMentionThis   String?   @map("research_mention_this")
  sourceUrl             String?   @map("source_url")
  pipelineStage         String    @default("identified") @map("pipeline_stage") // identified | contacted | responded | chatted | applied | interviewing
  notes                 String?
  deletedAt             DateTime? @map("deleted_at") // soft delete (D-16)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  search   Search    @relation(fields: [searchId], references: [id])
  outreach Outreach[]

  @@map("contacts")
}

// ============================================
// OUTREACH
// Draft emails generated by the Email Drafter agent
// sentAt/sentVia track delivery method
// ============================================
model Outreach {
  id           String    @id @default(uuid())
  contactId    String    @map("contact_id")
  templateType String    @map("template_type") // referral_ask | hiring_inquiry | value_offer | followup_1 | followup_2
  subject      String
  body         String
  tone         String                           // direct | curious | value_driven
  sentAt       DateTime? @map("sent_at")
  sentVia      String?   @map("sent_via")       // "clipboard" | "mailto" | "gmail_api"
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  contact Contact @relation(fields: [contactId], references: [id])

  @@map("outreach")
}

// ============================================
// GUEST IP LIMIT
// IP-based rate limiting for guest searches (D-01)
// date field resets daily; unique per IP+date pair
// Only accessible via service role key (no user RLS policies needed)
// ============================================
model GuestIpLimit {
  id          String   @id @default(uuid())
  ipAddress   String   @map("ip_address")
  searchCount Int      @default(0) @map("search_count")
  date        DateTime @default(now()) @db.Date // resets daily

  @@unique([ipAddress, date])
  @@map("guest_ip_limits")
}

// ============================================
// COMPANY ENRICHMENT
// Caches Firecrawl/Claude Haiku research on a domain
// Re-used across different users searching the same company
// ============================================
model CompanyEnrichment {
  id        String   @id @default(uuid())
  domain    String   @unique
  data      Json
  cachedAt  DateTime @map("cached_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("company_enrichments")
}

