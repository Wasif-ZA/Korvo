# Demo Mode Configuration
# Run: npm run demo
# This sets up Korvo in fully self-contained demo mode:
# - No Supabase connection needed
# - No Claude API calls (uses seed data)
# - No Redis/BullMQ workers (async simulated)
# - No Stripe connection (all users are "Pro")
# - No Gmail send (toasts show success)

NEXT_PUBLIC_DEMO_MODE=true

# Required by Next.js but unused in demo
NEXT_PUBLIC_SUPABASE_URL=https://demo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.demo

# Demo user auth (unused — mocked)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Not needed in demo (API calls mocked)
ANTHROPIC_API_KEY=demo-key-not-used
STRIPE_SECRET_KEY=demo-key-not-used
