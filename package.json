{
  "name": "korvo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "demo": "node scripts/setup-demo.mjs && npm run dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "env:check": "tsx scripts/check-env.ts --mode=runtime",
    "env:check:build": "tsx scripts/check-env.ts --mode=build",
    "env:check:dev": "tsx scripts/check-env.ts --mode=dev",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "queue:dev": "tsx src/workers/index.ts || tsx worker/index.ts",
    "dev:worker": "tsx watch worker/index.ts",
    "start:worker": "tsx worker/index.ts",
    "predev": "npm run env:check:dev",
    "prebuild": "npm run env:check:build && prisma generate",
    "build:analyze": "ANALYZE=true next build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mendable/firecrawl-js": "^4.18.1",
    "@prisma/client": "^7.6.0",
    "@sentry/nextjs": "^10.47.0",
    "@sentry/node": "^10.47.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "bullmq": "^5.73.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "opossum": "^9.0.0",
    "p-retry": "^8.0.0",
    "posthog-js": "^1.364.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "stripe": "^21.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/opossum": "^8.1.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.2.4",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
